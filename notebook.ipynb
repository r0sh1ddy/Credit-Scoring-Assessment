cells.append(code("""\
# 3.4 Impute missing values
feature_cols = [c for c in df_proc.columns if c != 'Credit_Score']
X_raw = df_proc[feature_cols]
y     = df_proc['Credit_Score']

imputer = SimpleImputer(strategy='median')
X_imp   = pd.DataFrame(imputer.fit_transform(X_raw), columns=X_raw.columns)
print(f'Missing values after imputation : {X_imp.isnull().sum().sum()}')
print(f'Total feature columns           : {X_imp.shape[1]}')"""))

cells.append(code("""\
# 3.5 Compare three scalers on Logistic Regression
X_tr_raw, X_te_raw, y_train, y_test = train_test_split(
    X_imp, y, test_size=0.2, random_state=SEED, stratify=y)

scalers = {
    'StandardScaler': StandardScaler(),
    'RobustScaler':   RobustScaler(),
    'MinMaxScaler':   MinMaxScaler(),
}
scaler_results = {}
for name, sc in scalers.items():
    Xtr = sc.fit_transform(X_tr_raw)
    Xte = sc.transform(X_te_raw)
    lr  = LogisticRegression(max_iter=1000, random_state=SEED)
    lr.fit(Xtr, y_train)
    p   = lr.predict(Xte)
    pr  = lr.predict_proba(Xte)
    scaler_results[name] = {
        'acc': accuracy_score(y_test, p),
        'auc': roc_auc_score(y_test, pr, multi_class='ovr', average='macro'),
    }
    print(f'{name:20s} | Acc: {scaler_results[name][\"acc\"]:.4f} '
          f'| AUC: {scaler_results[name][\"auc\"]:.4f}')

best_scaler_name = max(scaler_results, key=lambda k: scaler_results[k]['auc'])
print(f'\\n→ Selected: {best_scaler_name}')
scaler = scalers[best_scaler_name]
X_train_s = scaler.fit_transform(X_tr_raw)
X_test_s  = scaler.transform(X_te_raw)"""))

# ─── 4. FEATURE ENGINEERING ────────────────────────────────────────────────────
cells.append(md("---\n## 4. Feature Engineering"))
cells.append(code("""\
def add_features(df):
    df = df.copy()
    df['Debt_to_Income']       = df['Outstanding_Debt']        / (df['Annual_Income']         + 1)
    df['EMI_to_Income']        = df['Total_EMI_per_month']     / (df['Monthly_Inhand_Salary'] + 1)
    df['Delayed_per_Loan']     = df['Num_of_Delayed_Payment']  / (df['Num_of_Loan']           + 1)
    df['Investment_to_Income'] = df['Amount_invested_monthly'] / (df['Monthly_Inhand_Salary'] + 1)
    df['Cards_per_Account']    = df['Num_Credit_Card']         / (df['Num_Bank_Accounts']     + 1)
    df['Loan_per_Account']     = df['Num_of_Loan']             / (df['Num_Bank_Accounts']     + 1)
    df['Balance_to_Income']    = df['Monthly_Balance']         / (df['Monthly_Inhand_Salary'] + 1)
    df['Inquiry_density']      = df['Num_Credit_Inquiries']    / (df['Credit_History_Age']    + 1)
    df['Delay_x_Debt']         = df['Delay_from_due_date']     * df['Outstanding_Debt']
    df['History_x_Mix']        = df['Credit_History_Age']      * df.get('Credit_Mix', 1)
    return df

X_train_fe = add_features(pd.DataFrame(X_train_s, columns=X_tr_raw.columns))
X_test_fe  = add_features(pd.DataFrame(X_test_s,  columns=X_te_raw.columns))

scaler2    = RobustScaler()
X_train_fs = scaler2.fit_transform(X_train_fe)
X_test_fs  = scaler2.transform(X_test_fe)
feat_names = X_train_fe.columns.tolist()
print(f'Features before engineering : {X_tr_raw.shape[1]}')
print(f'Features after  engineering : {len(feat_names)}')"""))

# ─── 5. RFECV ─────────────────────────────────────────────────────────────────
cells.append(md("---\n## 5. Recursive Feature Elimination (RFECV)"))
cells.append(code("""\
# Class-weight balancing instead of SMOTE (no imbalanced-learn required)
rfecv = RFECV(
    estimator=ExtraTreesClassifier(
        n_estimators=100, class_weight='balanced',
        random_state=SEED, n_jobs=-1),
    step=1,
    cv=StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED),
    scoring='roc_auc_ovr',
    min_features_to_select=8,
    n_jobs=-1
)
rfecv.fit(X_train_fs, y_train)
print(f'Optimal features: {rfecv.n_features_} / {X_train_fs.shape[1]}')

# RFECV curve
fig, ax = plt.subplots(figsize=(10, 4))
scores  = rfecv.cv_results_['mean_test_score']
stds    = rfecv.cv_results_['std_test_score']
x_vals  = range(1, len(scores)+1)
ax.plot(x_vals, scores, color='#3b82f6', lw=2)
ax.fill_between(x_vals, scores-stds, scores+stds, alpha=0.2, color='#3b82f6')
ax.axvline(rfecv.n_features_, color='red', ls='--', label=f'Optimal: {rfecv.n_features_}')
ax.set_xlabel('Number of Features'); ax.set_ylabel('CV ROC-AUC')
ax.set_title('RFECV — Feature Selection Curve', fontweight='bold')
ax.legend(); plt.tight_layout(); plt.show()

selected_mask  = rfecv.support_
selected_feats = [f for f, s in zip(feat_names, selected_mask) if s]
X_train_sel    = X_train_fs[:, selected_mask]
X_test_sel     = X_test_fs[:,  selected_mask]
print('Selected features:', selected_feats)"""))

cells.append(code("""\
# Feature importance from RFECV estimator
importances = rfecv.estimator_.feature_importances_[selected_mask]
fi_df = pd.Series(importances, index=selected_feats).sort_values()

fig, ax = plt.subplots(figsize=(10, max(5, len(selected_feats)*0.35)))
colors_fi = [COLORS[i % len(COLORS)] for i in range(len(fi_df))]
fi_df.plot(kind='barh', ax=ax, color=colors_fi, edgecolor='white')
ax.set_title('Feature Importances — RFECV Selected Features', fontweight='bold')
ax.set_xlabel('Importance'); plt.tight_layout(); plt.show()"""))

