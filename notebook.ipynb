"""
Build the Credit Score Analysis Jupyter Notebook.
Uses only stdlib + sklearn/matplotlib/seaborn/scipy/joblib (no xgboost/shap/optuna).
"""
import json, os

def cell(cell_type, source, **kw):
    base = {"cell_type": cell_type, "metadata": {}, "source": source}
    if cell_type == "code":
        base.update({"execution_count": None, "outputs": []})
    return base

def md(src):  return cell("markdown", src)
def code(src): return cell("code", src)

