    raw  = df_proc[feat].dropna()
    logd = df_proc[f'{feat}_log'].dropna()
    axes[0,i].hist(raw,  bins=50, color='#ef4444', alpha=0.7, density=True)
    axes[0,i].set_title(f'{feat[:14]}\\nSkew={raw.skew():.2f}', fontsize=8)
    axes[1,i].hist(logd, bins=50, color='#22c55e', alpha=0.7, density=True)
    axes[1,i].set_title(f'log({feat[:12]})\\nSkew={logd.skew():.2f}', fontsize=8)
axes[0,0].set_ylabel('Before (raw)'); axes[1,0].set_ylabel('After (log)')
