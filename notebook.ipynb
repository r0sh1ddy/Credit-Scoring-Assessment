from scipy.stats import randint, uniform

# ── Random Forest ────────────────────────────────────────────────────────────
param_dist_rf = {
    'n_estimators':     randint(100, 500),
    'max_depth':        [None, 6, 8, 10, 14],
    'min_samples_leaf': randint(1, 10),
    'max_features':     ['sqrt','log2', 0.5, 0.7],
    'class_weight':     ['balanced', None],
}
