# ─── 10. PREDICTION FUNCTION ──────────────────────────────────────────────────
cells.append(md("""\
---
## 10. Prediction Function

A production-ready function that accepts either a dict of raw inputs or a
pandas DataFrame, runs the full preprocessing pipeline, and returns class
label + confidence probabilities."""))

cells.append(code("""\
def predict_credit_score(raw_input, model=None, verbose=True):
    \"\"\"
    Predict credit score class for one or more applicants.

    Parameters
    ----------
    raw_input : dict | pd.DataFrame
        Raw feature values (same schema as training data, Credit_Score excluded).
    model : fitted sklearn classifier | None
        If None, uses the best model found during training.
    verbose : bool
        Print a human-readable report.

    Returns
    -------
    pd.DataFrame with columns: Prediction, Poor_prob, Standard_prob, Good_prob, Confidence
    \"\"\"
    if model is None:
        model = results[best_name]['model']

    if isinstance(raw_input, dict):
        df_in = pd.DataFrame([raw_input])
    else:
        df_in = raw_input.copy()

    # ── Preprocessing (mirror training pipeline) ─────────────────────────
    # Log transforms
    for feat in LOG_FEATURES:
        if feat in df_in.columns:
            df_in[f'{feat}_log'] = np.log1p(df_in[feat].fillna(0))

    # Rebinning
    df_in['Age_bin'] = pd.cut(df_in['Age'],
        bins=[17,25,35,50,65,76],
        labels=['Young Adult','Adult','Mid-Career','Pre-Senior','Senior'])
    df_in['Income_quartile'] = pd.cut(
        df_in['Annual_Income'].fillna(df_in['Annual_Income'].median()),
        bins=[0, 30000, 65000, 120000, 1e9],
        labels=['Low','Below-Avg','Above-Avg','High'])
    df_in['History_tier'] = pd.cut(df_in['Credit_History_Age'],
        bins=[-0.1,3,8,18,36],
        labels=['New','Growing','Established','Veteran'])
    df_in['Debt_tier'] = pd.cut(
        df_in['Outstanding_Debt'].fillna(df_in['Outstanding_Debt'].median()),
        bins=[-0.1, 1600, 3300, 5001],
        labels=['Low','Medium','High'])

    # Encode
    for col, enc in encoders.items():
        if col in df_in.columns:
            try:
                df_in[col] = enc.transform(df_in[col].astype(str))
            except Exception:
                df_in[col] = 0   # unseen label fallback

    # Align columns
    for c in feature_cols:
        if c not in df_in.columns:
            df_in[c] = 0
    df_in = df_in[feature_cols]

    # Impute
    X_in = pd.DataFrame(imputer.transform(df_in), columns=df_in.columns)

    # Scale
    X_sc = scaler.transform(X_in)

    # Feature engineering
    X_fe = add_features(pd.DataFrame(X_sc, columns=X_in.columns))
    X_sc2 = scaler2.transform(X_fe)

    # RFE mask
    X_sel = X_sc2[:, selected_mask]

    # Predict
    preds = model.predict(X_sel)
    proba = model.predict_proba(X_sel)

    out = pd.DataFrame({
        'Prediction':    [LABEL_MAP[p] for p in preds],
        'Poor_prob':     proba[:,0].round(4),
        'Standard_prob': proba[:,1].round(4),
        'Good_prob':     proba[:,2].round(4),
        'Confidence':    proba.max(axis=1).round(4),
    })

    if verbose:
        for i, row in out.iterrows():
            print(f'\\n── Applicant {i+1} ──────────────────────────────')
            print(f'  Credit Score : {row[\"Prediction\"]}')
            print(f'  Confidence   : {row[\"Confidence\"]*100:.1f}%')
            print(f'  Probabilities:  Poor={row[\"Poor_prob\"]*100:.1f}%  '
                  f'Standard={row[\"Standard_prob\"]*100:.1f}%  '
                  f'Good={row[\"Good_prob\"]*100:.1f}%')
    return out

# ── Demo ──────────────────────────────────────────────────────────────────────
sample_applicant = {
    'Age': 34, 'Occupation': 'Engineer', 'Annual_Income': 85000,
    'Monthly_Inhand_Salary': 7083, 'Num_Bank_Accounts': 3,
    'Num_Credit_Card': 4, 'Interest_Rate': 11.5, 'Num_of_Loan': 2,
    'Delay_from_due_date': 5, 'Num_of_Delayed_Payment': 1,
    'Changed_Credit_Limit': 8.0, 'Num_Credit_Inquiries': 3,
    'Credit_Mix': 'Good', 'Outstanding_Debt': 1200,
    'Credit_Utilization_Ratio': 28.5, 'Credit_History_Age': 12,
    'Payment_of_Min_Amount': 'Yes', 'Total_EMI_per_month': 450,
    'Amount_invested_monthly': 800, 'Monthly_Balance': 1500,
}
result = predict_credit_score(sample_applicant)
result"""))

