# ════════════════════════════════════════════════════════════
# OPTION B — Real Kaggle dataset
# ────────────────────────────────────────────────────────────
# df = pd.read_csv('train.csv')
# df['Credit_Score'] = df['Credit_Score'].map({'Poor':0,'Standard':1,'Good':2})
