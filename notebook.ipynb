# 3.1 Log-transform right-skewed features
LOG_FEATURES = ['Annual_Income','Outstanding_Debt','Total_EMI_per_month',
                'Monthly_Inhand_Salary','Amount_invested_monthly']

df_proc = df.copy()
for feat in LOG_FEATURES:
    df_proc[f'{feat}_log'] = np.log1p(df_proc[feat].fillna(0))

# Visual comparison
fig, axes = plt.subplots(2, len(LOG_FEATURES), figsize=(18, 6))
